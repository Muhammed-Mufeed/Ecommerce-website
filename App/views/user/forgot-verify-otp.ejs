<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verify OTP</title>
  <link rel="stylesheet" href="/user/css/signup.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
  <div class="card p-4" style="width: 400px;">
    <h3 class="text-center mb-3">Verify OTP</h3>

    <% if (isDemoMode) { %>
    <div class="alert alert-warning text-center" id="demoBanner" role="alert" style="font-size: 0.85rem;">
      <strong>⚠️ Demo Environment Active</strong><br>
      Due to API sandbox restrictions, email delivery is disabled. <br>
      Please enter test OTP: <b id="displayOtp" style="font-size: 1.1rem; letter-spacing: 1px; color: #d32f2f;"><%= demoOtp %></b>
    </div>
    <% } %>
    <form id="verifyOtpForm">
      <div class="mb-3">
        <label for="otp" class="form-label">Enter OTP</label>
        <input type="text" class="form-control" id="otp" placeholder="6-digit OTP" required>
      </div>
      <button type="submit" class="btn btn-primary w-100">Verify OTP</button>
    </form>
    <hr>
    <div class="timer" id="timer">Resend OTP in 60 seconds</div>
    <button id="resendOtpButton" class="btn btn-secondary w-100 mt-2" disabled>Resend OTP</button>
  </div>

  <script>
    let timerDuration = 60;
    let timerElement = document.getElementById("timer");
    let resendButton = document.getElementById("resendOtpButton");
    let resendAllowed = false;

    function startTimer() {
      resendButton.disabled = true;
      resendAllowed = false;
      let remainingTime = timerDuration;

      const timerInterval = setInterval(() => {
        if (remainingTime > 0) {
          timerElement.textContent = `Resend OTP in ${remainingTime--} seconds`;
          timerElement.style.color = "#007bff";
        } else {
          clearInterval(timerInterval);
          timerElement.textContent = "You can now resend the OTP.";
          timerElement.style.color = "#28a745";
          resendButton.disabled = false;
          resendAllowed = true;
        }
      }, 1000);
    }

    startTimer();

    document.getElementById("verifyOtpForm").addEventListener("submit", async function (e) {
      e.preventDefault();
      const otp = document.getElementById("otp").value;

      try {
        const response = await fetch("/forgot-verify-otp", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({ otp }),
        });

        const data = await response.json();

        if (data.success) {
          Swal.fire({
            icon: "success",
            title: "OTP Verified!",
            text: data.message || "Redirecting to reset password...",
          }).then(() => {
            window.location.href = data.redirectUrl || "/forgot-confirm-password";
          });
        } else {
          Swal.fire({
            icon: "error",
            title: "Verification Failed",
            text: data.message || "Please try again.",
          });
        }
      } catch (error) {
        console.error("Error verifying OTP:", error);
        Swal.fire({
          icon: "error",
          title: "Error",
          text: "Something went wrong. Please try again.",
        });
      }
    });

    resendButton.addEventListener("click", async function () {
      if (!resendAllowed) return;
      resendAllowed = false;
      resendButton.disabled = true;
      timerElement.textContent = "Processing...";
      timerElement.style.color = "#ffc107";

      try {
        const response = await fetch("/resend-otp", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
        });

        const data = await response.json();

        if (!data.success) {
          throw new Error(data.message || "Please try again later");
        }

        // ================== SMART CONDITIONAL UI ================== //
        if (data.isDemoMode) {
          // If a recruiter is testing: Update the banner and show the SweetAlert with the OTP
          const displayElement = document.getElementById("displayOtp");
          if(displayElement) displayElement.innerText = data.newDemoOtp;

          Swal.fire({
            icon: "success",
            title: "OTP Sent!",
            text: `New Demo OTP Generated: ${data.newDemoOtp}`,
          });
        } else {
          // If YOU are testing (real email): Tell them to check their inbox!
          Swal.fire({
            icon: "success",
            title: "Email Sent!",
            text: "A real OTP has been successfully sent to your inbox.",
          });
        }
        // ========================================================== //

        startTimer();
      } catch (error) {
        console.error("Error resending OTP:", error);
        Swal.fire({
          icon: "error",
          title: "Error",
          text: error.message || "Something went wrong. Please try again.",
        });

        timerElement.textContent = "You can now resend the OTP.";
        timerElement.style.color = "#28a745";
        resendButton.disabled = false;
        resendAllowed = true;
      }
    });
  </script>
</body>
</html>